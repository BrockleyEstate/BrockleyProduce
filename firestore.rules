rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (required)
    //   - role: string (required, 'consumer' or 'farmer')
    //   - farmName: string (optional)
    //   - location: string (optional)
    //   - fullStory: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: products
    // Document ID: {productId}
    // Fields:
    //   - name: string (required)
    //   - description: string (required)
    //   - price: number (required)
    //   - unit: string (required)
    //   - category: string (required)
    //   - images: list (optional)
    //   - farmerId: string (required)
    //   - productionDetails: list (optional)
    //   - inStock: boolean (required)
    //   - deliveryOptions: list (optional)
    //   - brockleyDeliveryFee: number (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: reviews
    // Document ID: {reviewId}
    // Fields:
    //   - farmerId: string (required)
    //   - buyerId: string (required)
    //   - buyerName: string (required)
    //   - rating: number (required, 1-5)
    //   - comment: string (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // Domain Validators
    function isValidUser(data) {
      return hasRequiredFields(['uid', 'email', 'displayName', 'role', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.role in ['consumer', 'farmer'] &&
             data.createdAt is timestamp &&
             (!( 'farmName' in data ) || (data.farmName is string && data.farmName.size() < 100)) &&
             (!( 'location' in data ) || (data.location is string && data.location.size() < 100)) &&
             (!( 'fullStory' in data ) || (data.fullStory is string && data.fullStory.size() < 2000));
    }

    function isValidProduct(data) {
      return hasRequiredFields(['name', 'description', 'price', 'unit', 'category', 'farmerId', 'inStock', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 2000 &&
             data.price is number && data.price >= 0 &&
             data.unit is string && data.unit.size() > 0 && data.unit.size() < 50 &&
             data.category in ['meat', 'veg', 'dairy', 'eggs', 'pantry', 'more'] &&
             data.farmerId is string && data.farmerId.size() > 0 && data.farmerId.size() < 100 &&
             data.inStock is bool &&
             data.createdAt is timestamp &&
             (!( 'images' in data ) || data.images is list) &&
             (!( 'productionDetails' in data ) || data.productionDetails is list) &&
             (!( 'deliveryOptions' in data ) || data.deliveryOptions is list) &&
             (!( 'brockleyDeliveryFee' in data ) || data.brockleyDeliveryFee is number);
    }

    function isValidReview(data) {
      return hasRequiredFields(['farmerId', 'buyerId', 'buyerName', 'rating', 'comment', 'createdAt']) &&
             data.farmerId is string && data.farmerId.size() > 0 && data.farmerId.size() < 100 &&
             data.buyerId is string && data.buyerId.size() > 0 && data.buyerId.size() < 100 &&
             data.buyerName is string && data.buyerName.size() > 0 && data.buyerName.size() < 100 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() > 0 && data.comment.size() < 1000 &&
             data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow read: if true; // Public profiles for farmers and consumers (denormalized info)
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && uidUnchanged();
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.farmerId && isValidProduct(request.resource.data);
      allow update: if isAuthenticated() && request.auth.uid == resource.data.farmerId && request.auth.uid == request.resource.data.farmerId && isValidProduct(request.resource.data) && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.farmerId;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.buyerId && isValidReview(request.resource.data);
      allow update: if isAuthenticated() && request.auth.uid == resource.data.buyerId && request.auth.uid == request.resource.data.buyerId && isValidReview(request.resource.data) && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.buyerId;
    }
  }
}
